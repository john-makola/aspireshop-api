# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aspireshop"

# JWT secret — use: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secret"

# Frontend origin for CORS
FRONTEND_URL="https://aspiregraphics.co.ke"

# Port (cPanel sets this automatically via Passenger)
PORT=4000

# Upload directory (absolute path on server)
# UPLOAD_DIR="/home/username/public_html/uploads"
